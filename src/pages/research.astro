---
import Layout from '../layouts/BaseLayout.astro';
---

<Layout>
  <section class="content-inner">
    <h1>Research</h1>
    <p>
      CVAMO conducts research at the intersection of data analytics, optimization, and decision support for complex business and industrial environments.
    </p>

    <h2>Publications</h2>
    <p>
      View the full publication list on
      <a href="https://biblio.ugent.be/publication?q=author+exact+..." target="_blank">
      UGent Biblio</a>.
    </p>
  </section>

  <section class="publications-iframe">
    <iframe
      src="https://biblio.ugent.be/publication?embed=1&&hide_info=1&hide_options=1"
      title="CVAMO publications"
      loading="lazy">
    </iframe>
  </section>
</Layout>
