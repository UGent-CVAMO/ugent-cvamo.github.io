---
import '../styles/global.css';
const { pathname } = Astro.url;
---

<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="CVAMO research lab – Data analytics, optimization and decision support at Ghent University." />
    <meta property="og:title" content="CVAMO – Ghent University" />
    <meta property="og:description" content="Cost and Value Analytics, Models & Optimization research lab." />
    <meta property="og:image" content="/images/cvamo-preview.png" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
    />
    <title>CVAMO - UGent</title>
</head>
<body>
  <div class="page-frame">
    <header class="masthead">
      <div class="logo-column">
        <a href="https://www.ugent.be/en">
          <img src="/logo-ugent-EN.svg" alt="UGent Logo" class="ugent-logo" />
        </a>
      </div>

      <div class="hero-banner">
      
        <div class="banner-links">
          <a href="https://www.ugent.be/eb/en">
            Home Faculty of Economics and Business Administration
          </a>
        </div>
      
        <h1 class="banner-title">
          <a href="/">
            COST AND VALUE ANALYTICS MODELS & OPTIMIZATION
          </a>
        </h1>
      
      </div>
    </header>

    <nav class="navigation-tabs">
      <ul class="tab-list">
        <li class={`tab-item ${pathname.startsWith("/about") ? "active" : ""}`}>
          <a href="/about">About</a>
        </li>
    
        <li class={`tab-item ${pathname.startsWith("/team") ? "active" : ""}`}>
          <a href="/team">Team</a>
        </li>
    
        <li class={`tab-item ${pathname.startsWith("/research") ? "active" : ""}`}>
          <a href="/research">Research</a>
        </li>
    
        <li class={`tab-item ${pathname.startsWith("/for-companies") ? "active" : ""}`}>
          <a href="/for-companies">For Companies</a>
        </li>
    
        <li class={`tab-item ${pathname.startsWith("/contact") ? "active" : ""}`}>
          <a href="/contact">Contact</a>
        </li>
      </ul>
    </nav>

    <main class="page-content">
      <div class="content-inner">
        <slot />
      </div>
    </main>
  </div>
  <footer class="ugent-footer">
    <div class="footer-inner">
      <a href="https://x.com/yourhandle" aria-label="X">
        <i class="fa-brands fa-x-twitter"></i>
      </a>
    
      <a href="https://linkedin.com/in/yourprofile" aria-label="LinkedIn">
        <i class="fa-brands fa-linkedin-in"></i>
      </a>
    </div>
  </footer>
</body>
</html>
